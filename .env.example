# Local PostgreSQL Configuration (Optional, for development)
# Uncomment these if you want to use a local PostgreSQL instance instead of Neon
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_NAME=senti_quant_db
# DB_USER=senti_admin
# DB_PASSWORD=your_secure_password_here

# Cloud Database (Neon Serverless PostgreSQL)
# Get your connection string from: https://console.neon.tech/
# Format: postgresql://[user]:[password]@[host]/[dbname]?sslmode=require&channel_binding=require
DATABASE_URL=postgresql://user:password@ep-example.ap-southeast-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# Hugging Face Token (Optional, for faster model downloads)
# Get your token from: https://huggingface.co/settings/tokens
# HF_TOKEN=hf_your_token_here

# GitHub Actions Environment (Set automatically by workflow, do not modify locally)
# PYTHONUNBUFFERED=1
# PYTHONPATH=/github/workspace
